# OAEA-specific pylint extras layered on top of tomte's canonical
# pylintrc. The [testenv:pylint] env concats tomte's base with this
# file into a merged rcfile at run time. Sections here MUST NOT
# duplicate sections in tomte's canonical (tomte ships [MASTER],
# [MESSAGES CONTROL], [DESIGN], [REFACTORING], [SIMILARITIES],
# [SPELLING]).

[IMPORTS]
ignored-modules=aiohttp,anchorpy,asn1crypto,bech32,coverage,cosmpy,Crypto,cryptography.fernet,docker,ecdsa,eth_account,eth_keys,eth_typing,git,google,hexbytes,lru,matplotlib,memory_profiler,multidict,numpy,openapi_core,openapi_spec_validator,psutil,pyaes,pytest,signal,solana,solders,toml,web3,werkzeug
